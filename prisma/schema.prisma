generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(cuid())
  name        String
  dateOfBirth DateTime
  createdAt   DateTime  @default(now())

  questions   Question[]
  sessions    Session[]
  orders      Order[]
}

model TarotReader {
  id             String    @id @default(cuid())
  name           String
  specialization String
  tier           ReaderTier
  price          Float
  rating         Float
  bio            String
  imageUrl       String?
  sessions       Session[]
}

model Question {
  id        String   @id @default(cuid())
  userId    String
  text      String
  category  String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model Session {
  id        String        @id @default(cuid())
  userId    String
  readerId  String
  type      SessionType
  status    SessionStatus @default(PENDING)
  createdAt DateTime      @default(now())

  user          User          @relation(fields: [userId], references: [id])
  reader        TarotReader   @relation(fields: [readerId], references: [id])
  order         Order?
  asyncReading  AsyncReading?
  messages      Message[]
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  sessionId String      @unique
  amount    Float
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())

  user      User        @relation(fields: [userId], references: [id])
  session   Session     @relation(fields: [sessionId], references: [id])
}

model AsyncReading {
  id          String              @id @default(cuid())
  sessionId   String              @unique
  status      AsyncReadingStatus  @default(PENDING)
  resultText  String?
  createdAt   DateTime            @default(now())
  completedAt DateTime?

  session     Session             @relation(fields: [sessionId], references: [id])
}

model Message {
  id         String      @id @default(cuid())
  sessionId  String
  senderType SenderType
  content    String
  createdAt  DateTime    @default(now())

  session    Session     @relation(fields: [sessionId], references: [id])
}

model InsightArticle {
  id        String   @id @default(cuid())
  title     String
  preview   String
  content   String
  category  String   @default("general")
  readTime  Int      @default(5)
  createdAt DateTime @default(now())
}

enum ReaderTier {
  FOUNDATION
  SENIOR
  MASTER
}

enum SessionType {
  LIVE
  ASYNC
}

enum SessionStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PENDING
  PAID
  REFUNDED
}

enum AsyncReadingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum SenderType {
  USER
  READER
}
